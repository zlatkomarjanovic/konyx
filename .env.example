# Sanity catalog
NEXT_PUBLIC_SANITY_PROJECT_ID=bnw13vog
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-18

# Server-only: write token for seed scripts (Editor permissions)
